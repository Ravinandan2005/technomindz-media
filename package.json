{
  "name": "technomindz-media",
  "displayName": "TechnoMindz Media Controller",
  "description": "Elevate your workspace. A sleek, powerful media controller to keep your focus sharp and your music perfectly synced. 🎶",
  "version": "0.0.1",
  "publisher": "technomindz",
  "icon": "resources/logo.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/Ravinandan2005/technomindz-media.git"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "media",
    "spotify",
    "music",
    "youtube",
    "media controller",
    "player",
    "technomindz",
    "technomindz media",
    "technomindz media controller",
    "technomindz media player",
    "technomindz media control",
    "music control"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "views": {
      "explorer": [
        {
          "type": "webview",
          "id": "technomindz-media.hub",
          "name": "TechnoMindz Media Hub",
          "icon": "resources/logo.svg"
        }
      ]
    },
    "commands": [
      {
        "command": "technomindz-media.playPause",
        "title": "Media: Play / Pause"
      },
      {
        "command": "technomindz-media.next",
        "title": "Media: Next Track"
      },
      {
        "command": "technomindz-media.previous",
        "title": "Media: Previous Track"
      },
      {
        "command": "technomindz-media.toggleVisibility",
        "title": "Media: Toggle Media Bar"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "technomindz-media.playPause",
          "when": "false"
        },
        {
          "command": "technomindz-media.next",
          "when": "false"
        },
        {
          "command": "technomindz-media.previous",
          "when": "false"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "esbuild": "^0.27.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}